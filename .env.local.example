# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio (WhatsApp OTP)
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_SMS_FROM=+1234567890

# Blockradar (Wallet Infrastructure)
BLOCKRADAR_API_KEY=your-blockradar-api-key
BLOCKRADAR_CELO_WALLET_ID=master-wallet-id-celo
BLOCKRADAR_BASE_WALLET_ID=master-wallet-id-base
BLOCKRADAR_POLYGON_WALLET_ID=master-wallet-id-polygon
BLOCKRADAR_TRON_WALLET_ID=master-wallet-id-tron
BLOCKRADAR_ETHEREUM_WALLET_ID=master-wallet-id-ethereum

# PollaBets Smart Contract
NEXT_PUBLIC_POLLA_BETS_ADDRESS=0x_DEPLOY_AND_PASTE_HERE
NEXT_PUBLIC_TREASURY_ADDRESS=0x_YOUR_HARDWARE_WALLET_ADDRESS
# USDC addresses are hardcoded per chain:
#   Celo mainnet:  0xcebA9300f2b948710d2653dD7B07f33A8B32118C
#   Celo Sepolia:  0x01C5C0122039549AD1493B8220cABEdD739BC44E

# Operator Wallet (server-side only — signs createMarket & resolve txs)
# Fund with $10-20 CELO for gas. NEVER holds USDC.
POLLA_OPERATOR_PRIVATE_KEY=0x_OPERATOR_PRIVATE_KEY

# Football Data API
# FOOTBALL_DATA_API_TOKEN is the newer name used by lib/footballdata/client.ts.
# FOOTBALL_DATA_API_KEY is the existing legacy name — either works; token wins.
FOOTBALL_DATA_API_KEY=your-football-data-api-key
# FOOTBALL_DATA_API_TOKEN=your-football-data-api-token
# Rate limit cap for the parlay settlement pipeline. Default 10/min (free
# tier). Raise to 30 / 60 if you upgrade subscription — see
# https://www.football-data.org/pricing.
FOOTBALL_DATA_RATE_PER_MINUTE=10
# Comma-separated football-data.org competition codes the parlay job
# watches. Default WC (FIFA World Cup). Example: WC,CL,PL.
PARLAY_COMPETITION_CODES=WC

# Parlay Pools Smart Contract
# Override to point at a specific SabiParlayPools deployment; if unset,
# falls back to the address embedded in lib/contracts/SabiParlayPools.json.
# NEXT_PUBLIC_PARLAY_POOLS_ADDRESS=0x...

# Cron Job Protection
CRON_SECRET=your-cron-secret
